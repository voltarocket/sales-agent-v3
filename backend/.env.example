PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://sales:sales_pass@localhost:5432/sales_agent

# Redis
REDIS_URL=redis://localhost:6379

# License key (issued by global-backend: POST /licenses/issue with X-Admin-Secret header)
# Leave empty for dev mode — no license enforcement
LICENSE_KEY=
# Unique ID for this device/installation (auto-generated from hostname if empty)
DEVICE_ID=

# Global backend (AI gateway)
GLOBAL_BACKEND_URL=http://localhost:3002
# Must match ADMIN_SECRET in global-backend/.env
GLOBAL_ADMIN_SECRET=change-me-in-production

# FreePBX / SIP
FREEPBX_HOST=localhost
FREEPBX_WS_PORT=8088
FREEPBX_DOMAIN=
FREEPBX_EXTENSION=1000
FREEPBX_PASSWORD=
FREEPBX_EXT_2=
FREEPBX_PASS_2=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: explicit ffmpeg path
# FFMPEG_PATH=/usr/bin/ffmpeg
