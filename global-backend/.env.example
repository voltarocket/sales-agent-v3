PORT=3002

# AI Providers — set at least one
GROQ_API_KEY=gsk_...
# YANDEX_API_KEY=...
# YANDEX_FOLDER_ID=...

# Licensing — PostgreSQL (shared with local-backend)
DATABASE_URL=postgresql://sales:sales_pass@localhost:5432/sales_agent

# Secret for admin operations (POST /licenses/issue, DELETE /licenses/:key)
ADMIN_SECRET=change-me-in-production

# Set to "true" to require a valid license on every /process and /analyze call
# Leave unset or "false" for dev mode (no license required)
REQUIRE_LICENSE=false

# Optional: explicit ffmpeg path
# FFMPEG_PATH=/usr/bin/ffmpeg
