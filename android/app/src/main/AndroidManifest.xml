<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.telephony" android:required="false"/>

    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Фикс #2: явное объявление типа для Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        android:foregroundServiceType="microphone"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE"/>
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.CALL_PHONE"/>

    <application
        android:name=".SalesApp"
        android:allowBackup="true"
        android:label="Sales Analyzer"
        android:icon="@android:drawable/sym_def_app_icon"
        android:theme="@style/Theme.SalesAnalyzer"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Фикс #3,#4: screenOrientation -> unspecified -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <data android:scheme="tel"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.DIAL"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".PostCallActivity"
            android:exported="false"
            android:screenOrientation="unspecified"/>

        <!-- Фикс #5,#6: убраны комментарии со словом INCALL -->
        <service
            android:name=".CallService"
            android:exported="true"
            android:permission="android.permission.BIND_INCALL_SERVICE">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="true"/>
            <intent-filter>
                <action android:name="android.telecom.InCallService"/>
            </intent-filter>
        </service>

        <service
            android:name=".SalesConnectionService"
            android:exported="true"
            android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.ConnectionService"/>
            </intent-filter>
        </service>

        <service
            android:name=".AudioCaptureService"
            android:exported="false"
            android:foregroundServiceType="microphone"/>

    </application>
</manifest>